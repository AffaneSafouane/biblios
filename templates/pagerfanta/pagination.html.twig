{%- extends 'pagerfanta/default.html.twig' -%}

{%- block pager_widget -%}
    <ul class="pagination">
        {{- block('pager') -}}
    </ul>
{%- endblock pager_widget -%}

{%- block page_link -%}
    <li class="page-item"><a class="page-link link-primary" style="background-color: #1b1e1f; border: 1px solid gray" href="{{- path -}}">{{- page -}}</a></li>
{%- endblock page_link -%}

{%- block current_page_link -%}
    <li class="page-item active" aria-current="page"><span class="page-link" >{{- page -}}</span></li>
{%- endblock current_page_link -%}

{%- block previous_page_link -%}
    <li class="page-item"><a class="page-link link-primary" style="background-color: #1b1e1f; border: 1px solid gray" href="{{- path -}}" rel="prev">{{- block('previous_page_message') -}}</a></li>
{%- endblock previous_page_link -%}

{%- block previous_page_link_disabled -%}
    <li class="page-item disabled"><span class="page-link" style="background-color: #1b1e1f; color: #919689; border: 1px solid gray">{{- block('previous_page_message') -}}</span></li>
{%- endblock previous_page_link_disabled -%}

{%- block next_page_link -%}
    <li class="page-item"><a class="page-link link-primary" style="background-color: #1b1e1f; border: 1px solid gray" href="{{- path -}}" rel="next">{{- block('next_page_message') -}}</a></li>
{%- endblock next_page_link -%}

{%- block next_page_link_disabled -%}
    <li class="page-item disabled"><span class="page-link" style="background-color: #1b1e1f; color: #919689; border: 1px solid gray">{{- block('next_page_message') -}}</span></li>
{%- endblock next_page_link_disabled -%}

{%- block ellipsis -%}
    <li class="page-item disabled"><span class="page-link" style="background-color: #1b1e1f; color: #919689; border: 1px solid gray">&hellip;</span></li>
{%- endblock ellipsis -%}
